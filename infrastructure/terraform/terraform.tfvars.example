aws_region   = "us-east-1"
project_name = "construction-dashboard"
environment  = "prod"

# Replace with your ECR image tag from CI/CD
# Example: 123456789012.dkr.ecr.<region>.amazonaws.com/construction-dashboard:sha-abc123
ecr_image_identifier = "<account>.dkr.ecr.<region>.amazonaws.com/construction-dashboard:<tag>"

cors_origin           = "https://app.example.com"
admin_bootstrap_token = "replace-me-with-secure-random-token"
alert_email_subscriptions = [
  "ops@example.com",
]

# Optional overrides
# db_multi_az                = true
# apprunner_min_size         = 1
# apprunner_max_size         = 4
# apprunner_max_concurrency  = 80
